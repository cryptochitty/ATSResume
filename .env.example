# AI Providers — fallback chain: Gemini → Groq → OpenRouter (all free tiers)
# At least one key required. App tries each in order until one succeeds.
GEMINI_API_KEY="MY_GEMINI_API_KEY"         # https://aistudio.google.com/app/apikey
GROQ_API_KEY="MY_GROQ_API_KEY"             # https://console.groq.com/keys
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY" # https://openrouter.ai/settings/keys

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# STRIPE_SECRET_KEY: Required for Stripe payments.
STRIPE_SECRET_KEY="sk_test_..."

# STRIPE_WEBHOOK_SECRET: Required for Stripe webhooks.
STRIPE_WEBHOOK_SECRET="whsec_..."

# VITE_STRIPE_PUBLISHABLE_KEY: Public key for Stripe.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
