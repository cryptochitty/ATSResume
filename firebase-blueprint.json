{
  "entities": {
    "Resume": {
      "title": "Resume",
      "description": "A user's resume data",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns this resume" },
        "title": { "type": "string", "description": "The title of the resume" },
        "personalInfo": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "location": { "type": "string" },
            "linkedin": { "type": "string" },
            "github": { "type": "string" }
          }
        },
        "summary": { "type": "string" },
        "experience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "company": { "type": "string" },
              "role": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    }
  },
  "firestore": {
    "/resumes/{resumeId}": {
      "schema": "Resume",
      "description": "Collection of user resumes"
    }
  }
}
